# Copy this file to .env.local and fill in values for local development.
# .env.local is gitignored. Production values live in the Vercel dashboard.

# Backend API base URL (e.g. http://localhost:5000 or https://api.shrunothi.com)
VITE_API_URL=http://localhost:5000

# Google OAuth client ID (same one used for the deployed site)
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Optional: shared password gate for staging. Leave blank to skip.
VITE_SITE_LOCK_PASSWORD=
